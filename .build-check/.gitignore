# ==========================================
# Root .gitignore for immo_lamis Monorepo
# ==========================================

# 1. Dependency Directories
node_modules/

# 2. Build Outputs
dist/
dist-tsc/
build/
coverage/

# 3. Environment Variables & Secrets
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# 4. OS / Editor & IDE Files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 5. Logs and Debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
*.log

# 6. Project specific exclusions
backend/uploads/

# 7. npm Workspaces — root lock file is canonical
# Sub-package lock files are ignored after `npm install` from root
backend/package-lock.json
frontend/package-lock.json

# Shared package has no runtime deps, ignore any accidental installs
shared/node_modules/
retry_log.txt
