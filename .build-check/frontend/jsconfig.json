{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@immo/shared": ["../shared/src/index.ts"],
      "@immo/shared/*": ["../shared/src/*"]
    },
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "allowSyntheticDefaultImports": true,
    "checkJs": false
  },
  "include": ["src", "../shared/src"],
  "exclude": ["node_modules", "dist"]
}
